{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tabibu",
  "version": "0.1.4",
  "identifier": "xr.seede.tabibu",
  "build": {
    "frontendDist": "../src",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Tabibu",
        "width": 1120,
        "height": 740,
        "minWidth": 960,
        "minHeight": 620,
        "titleBarStyle": "Visible"
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": ["icons/icon.icns", "icons/icon.png"],
    "macOS": {
      "minimumSystemVersion": "13.0"
    }
  }
}
