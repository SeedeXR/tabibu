# Rust
core/target/
target/

# SwiftPM
.build/

# Packaging output (apps, dmgs, staged libs)
build/
*.dmg

# macOS / Xcode noise
.DS_Store
xcuserdata/

memory/

# Bench baselines are hardware-specific; never commit (see scripts/bench-gate.sh)
core/benches-baseline/

# Tauri / Node
app/src-tauri/target/
app/src-tauri/gen/
app/node_modules/

# Docs site: deps + the HTML generated from Markdown by docs/build.mjs in CI.
# Markdown is the source of truth; index.html is the only committed HTML.
docs/node_modules/
docs/**/*.html
!docs/index.html
